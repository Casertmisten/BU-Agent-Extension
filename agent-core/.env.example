# LLM 配置
# provider 可选: openai, dashscope, custom_local（需要填写BASE_URL）
LLM_PROVIDER=dashscope
LLM_MODEL=glm-5.1
LLM_API_KEY=your-api-key-here
# LLM_BASE_URL=http://58.251.255.50:8229/v1

# VLM 配置
# provider 可选: openai, dashscope, custom_local（需要填写BASE_URL）
VLM_PROVIDER=dashscope
VLM_MODEL=qwen3.6-35b-a3b
VLM_API_KEY=your-api-key-here
# VLM_BASE_URL=http://58.251.255.50:8229/v1

# 服务器配置
SERVER_HOST=localhost
SERVER_PORT=8765
HEARTBEAT_INTERVAL=30

# 日志级别
LOG_LEVEL=DEBUG
