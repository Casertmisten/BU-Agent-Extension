{
  "manifest_version": 3,
  "name": "Browser Use Agent",
  "version": "0.1.0",
  "description": "基于 SidePanel 的 AI 浏览器自动化",
  "permissions": [
    "sidePanel",
    "scripting",
    "tabs",
    "debugger",
    "alarms",
    "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "icons": {}
}
